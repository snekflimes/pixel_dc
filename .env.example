# Собственный PeerServer вместо облака (облако часто возвращает server-error).
# Поднять локально: npm run peer:signal
# VITE_PEERJS_HOST=localhost
# VITE_PEERJS_PORT=9000
# VITE_PEERJS_PATH=/
# VITE_PEERJS_KEY=peerjs
# VITE_PEERJS_SECURE=false

# Прод (пример): отдельный поддомен или тот же VPS за nginx + wss
# VITE_PEERJS_HOST=peer.snek.su
# VITE_PEERJS_PORT=443
# VITE_PEERJS_PATH=/
# VITE_PEERJS_SECURE=true
